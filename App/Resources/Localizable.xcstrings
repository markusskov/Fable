    "A brand-new story every night, whenever you want one": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeden Abend eine ganz neue Geschichte, wann immer du magst"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un cuento nuevo cada noche, siempre que quieras"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une histoire toute neuve chaque soir, quand tu en as envie"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una storia tutta nuova ogni sera, quando vuoi tu"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En splitter ny historie hver kveld, når du vil"
          }
        }
      }
    },
    "A favorite friend or animal — skip it and a small brave fox steps in": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Lieblingsfreund oder ein Tier – lässt du es frei, springt ein kleiner mutiger Fuchs ein"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un amigo favorito o un animal – si lo dejas en blanco, un pequeño zorro valiente ocupa su lugar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un ami préféré ou un animal, sinon un petit renard courageux prendra le relais"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un amico del cuore o un animale, altrimenti arriva una piccola volpe coraggiosa"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En yndlingsvenn eller et dyr – hopper du over, stiller en liten modig rev opp"
          }
        }
      }
    },
