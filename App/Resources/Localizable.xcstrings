            "value": "Fortell kveldens historie"
          }
        }
      }
    },
    "The End": {
      "comment": "Closing mark on the last page. Norwegian uses the traditional fairy-tale ending.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ende gut, alles gut"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Y colorín colorado, este cuento se ha acabado"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cric, crac, l'histoire est finie"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "E qui la storia si addormenta"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Snipp, snapp, snute"
          }
        }
      }
    },
    "The adventure continues another night": {
