    "Tonight's story will appear here, ready to read again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hier erscheint die Geschichte von heute Abend, bereit, noch einmal gelesen zu werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El cuento de esta noche aparecerá aquí, listo para leerlo otra vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'histoire du soir apparaîtra ici, prête à être relue."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La storia della sera apparirà qui, pronta da rileggere."
          }
