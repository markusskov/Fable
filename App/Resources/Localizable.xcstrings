            "state": "translated",
            "value": "Trykk eller sveip for å begynne"
          }
        }
      }
    },
    "Tell tonight's story": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Gutenachtgeschichte erzählen"
          }
        },
        "es": {
