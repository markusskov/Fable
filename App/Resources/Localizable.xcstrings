        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starte deine Gratiswoche"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza tu semana gratis"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commence ta semaine gratuite"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia la tua settimana gratuita"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Start gratisuken din"
          }
        }
      }
    },
    "Still private: everything stays on this device": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Weiterhin privat: Alles bleibt auf diesem Gerät"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Privado como siempre: todo se queda en este dispositivo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toujours privé : tout reste sur cet appareil"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sempre privato: tutto resta su questo dispositivo"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fortsatt privat: alt blir på denne enheten"
          }
        }
      }
    },
    "Story series — adventures that continue night after night": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geschichtenserien – Abenteuer, die Abend für Abend weitergehen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Series de cuentos – aventuras que continúan noche tras noche"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des séries d'histoires : des aventures qui continuent soir après soir"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Storie a puntate: avventure che continuano sera dopo sera"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Historieserier – eventyr som fortsetter kveld etter kveld"
          }
        }
      }
    },
    "Storybook": {
      "comment": "The library of past stories: toolbar accessibility label and navigation title",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geschichtenbuch"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Libro de cuentos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Livre d'histoires"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Libro delle storie"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Eventyrbok"
          }
        }
      }
    },
    "Subscriptions renew automatically until cancelled — cancel anytime in Settings. The free tier is yours forever: one new story every week, and every story you've told stays in your library.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Abo verlängert sich automatisch, bis es gekündigt wird – kündbar jederzeit in den Einstellungen. Die Gratisstufe gehört dir für immer: jede Woche eine neue Geschichte, und jede Geschichte, die du erzählt hast, bleibt in deinem Geschichtenbuch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La suscripción se renueva automáticamente hasta que se cancele – puedes cancelarla cuando quieras en Ajustes. El nivel gratuito es tuyo para siempre: un cuento nuevo cada semana, y cada cuento que hayas contado se queda en tu biblioteca."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'abonnement se renouvelle automatiquement jusqu'à sa résiliation, possible à tout moment dans Réglages. L'offre gratuite est à toi pour toujours : une nouvelle histoire chaque semaine, et toutes les histoires racontées restent dans ta bibliothèque."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'abbonamento si rinnova automaticamente finché non viene disdetto, in qualsiasi momento da Impostazioni. Il piano gratuito è tuo per sempre: una nuova storia ogni settimana, e ogni storia raccontata resta nella tua libreria."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Abonnementet fornyes automatisk til det sies opp – si opp når som helst i Innstillinger. Gratisnivået er ditt for alltid: én ny historie hver uke, og hver historie du har fortalt, blir stående i biblioteket."
          }
        }
      }
    },
    "Sweet dreams, %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Träum süß, %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dulces sueños, %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fais de beaux rêves, %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sogni d'oro, %@."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sov godt, %@."
          }
        }
      }
    },
    "Switch child. %@ is active.": {
      "comment": "VoiceOver label on the profile switcher menu",
