          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ahora mismo no encontramos la librería.\nInténtalo de nuevo un poco más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
